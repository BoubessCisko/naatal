# Copier en `.env.local` et remplir avec les vraies valeurs.
# `.env.local` est gitignored — ne jamais le commit.

# Appwrite — visibles côté client (préfixe EXPO_PUBLIC_)
# Endpoint dépend de la région du projet : fra (Frankfurt), nyc (New York), syd (Sydney)
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=xxxxxxxxxxxxxxxxxxxx

# Phone Auth mode :
#   false (default) → mock OTP en dev (magic code 123456, session anonyme Appwrite, pas de SMS)
#   true            → vraie Phone Auth via Twilio configuré dans Appwrite
EXPO_PUBLIC_USE_REAL_OTP=false

# === Secrets — JAMAIS de préfixe EXPO_PUBLIC_ (sinon bundlé dans l'APK) ===

# API Key pour la CLI Appwrite (push tables/buckets/functions).
# Génère-la dans Console → Overview → Integrations → API keys (pas Dev keys !)
# Scopes : databases, tables, columns, indexes, documents, buckets, files
APPWRITE_API_KEY=

# Secrets Functions (configurés dans Console → Functions → <function> → Variables) :
# NIN_HASH_SALT=                # Salt pour hash NIN dans la function hash-nin
# TWILIO_*                      # Géré directement dans Appwrite Messaging Providers, pas ici
